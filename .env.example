# Hermes Multi-Agent System 环境配置示例
# 复制此文件为 .env 并填入实际的配置值

# ===== OpenAI 配置 =====
# OpenAI API 密钥 (用于 GPT 模型)
OPENAI_API_KEY=sk-your-api-key-here

# OpenAI API 基础 URL (可选，用于自托管或代理)
OPENAI_API_BASE=https://api.openai.com/v1

# ===== Anthropic 配置 =====
# Claude API 密钥 (用于 Claude 模型)
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# ===== Google 配置 =====
# Google AI API 密钥 (用于 Gemini 模型)
GOOGLE_API_KEY=your-google-api-key-here

# ===== 数据库配置 =====
# MySQL 数据库配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=agent_db

# Redis 配置
REDIS_URL=redis://localhost:6379
REDIS_DB=0
REDIS_PASSWORD=

# Elasticsearch 配置
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_PREFIX=hermes_chat

# ===== 应用配置 =====
# FastAPI 应用端口
APP_PORT=8000

# 应用运行环境
APP_ENV=development

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ===== LLM 模型配置 =====
# 默认模型名称
DEFAULT_MODEL_NAME=gpt-3.5-turbo

# 默认模型提供商 (openai, anthropic, google_genai, together, etc.)
DEFAULT_MODEL_PROVIDER=openai

# 模型温度 (0.0 - 2.0, 默认 0.7)
DEFAULT_TEMPERATURE=0.7

# ===== 系统配置 =====
# 最多保存的最近消息数
MAX_RECENT_MESSAGES=30

# 消息保留天数
MESSAGE_RETENTION_DAYS=7

# Embedding 模型
EMBEDDING_MODEL=bge-large-zh-v1.5

# ===== 测试配置 =====
# 测试模式 (如果启用，某些检查会被跳过)
TEST_MODE=false

# 测试用 token
TEST_TOKEN=test_token_12345
