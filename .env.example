# ============================================================
# Hermes Multi-Agent Server — 环境配置示例
# 复制此文件为 .env 并填入实际值后启动服务
# ============================================================

# ===== MySQL 数据库 =====
# 完整连接串格式: mysql+pymysql://<user>:<password>@<host>:<port>/<database>
MYSQL_URL=mysql+pymysql://root:your_password@localhost:3306/agent_db

# ===== Redis =====
# 无密码: redis://localhost:6379/0
# 有密码: redis://:your_password@localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# ===== Elasticsearch =====
# 无认证: http://localhost:9200
# 有认证: http://user:password@localhost:9200
ELASTICSEARCH_URL=http://localhost:9200

# ===== Embedding 服务 =====
# Ollama 本地（无需 api_key）:
#   EMBEDDING_API_URL=http://localhost:11434
#   EMBEDDING_API_KEY=
#
# 在线服务（以 SiliconFlow 为例）:
#   EMBEDDING_API_URL=https://api.siliconflow.cn
#   EMBEDDING_API_KEY=sk-your-key-here
EMBEDDING_API_URL=http://localhost:11434
EMBEDDING_API_KEY=

# ===== LLM API Keys =====
# 用户可通过 /api/models/create 接口在界面配置模型
# 以下为可选的全局预设（留空则完全依赖用户界面配置）
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
GOOGLE_API_KEY=your-google-api-key-here

# ===== 应用配置 =====
# FastAPI 监听端口
APP_PORT=8000

# 运行环境: development / production
APP_ENV=development

# 日志级别: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ===== 测试配置 =====
TEST_MODE=false
TEST_TOKEN=test_token_12345
